# Backend environment variables
# Rename this file to backend/.env and set real values in production.

PORT=5000
FRONTEND_URL=https://your-vercel-app.vercel.app
JWT_SECRET=your_jwt_secret
LANDLORD_USERNAME=admin
LANDLORD_PASSWORD=strongpassword

# Database connection (currently MariaDB/MySQL)
DB_HOST=your-db-host
DB_PORT=3306
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=511_homes

# Optional socket path if using Unix socket connection
# DB_SOCKET=/path/to/socket

# Email settings for sending agreement PDFs
EMAIL_USER=youremail@gmail.com
EMAIL_PASS=your-email-password
